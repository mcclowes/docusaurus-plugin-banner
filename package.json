{
  "name": "docusaurus-plugin-banner",
  "version": "0.4.0",
  "description": "A customizable dismissable banner plugin for Docusaurus sites with localStorage persistence.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.mjs",
      "require": "./dist/client/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "example:start": "npm --prefix examples/docusaurus-v3 run start",
    "example:build": "npm --prefix examples/docusaurus-v3 run build",
    "example:serve": "npm --prefix examples/docusaurus-v3 run serve",
    "example:clear": "npm --prefix examples/docusaurus-v3 run clear",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "prepare": "husky",
    "prepublishOnly": "npm run build && npm test"
  },
  "peerDependencies": {
    "@docusaurus/types": "^3.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@docusaurus/core": "^3.0.0",
    "@docusaurus/types": "^3.0.0",
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.42.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "lint-staged": "^15.5.1",
    "prettier": "^3.2.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^4.1.5"
  },
  "keywords": [
    "docusaurus",
    "plugin",
    "banner",
    "dismissable",
    "notification",
    "localstorage",
    "typescript"
  ],
  "author": "mcclowes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcclowes/docusaurus-plugin-banner.git"
  },
  "bugs": {
    "url": "https://github.com/mcclowes/docusaurus-plugin-banner/issues"
  },
  "homepage": "https://github.com/mcclowes/docusaurus-plugin-banner#readme",
  "engines": {
    "node": ">=20.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
